{
  "name": "@kb/api-worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "dev:remote": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply knowledge-base --local",
    "db:migrate:remote": "wrangler d1 migrations apply knowledge-base --remote",
    "db:create": "wrangler d1 create knowledge-base",
    "vectorize:create": "wrangler vectorize create knowledge-base-embeddings --dimensions=384 --metric=cosine"
  },
  "dependencies": {
    "@kb/shared": "workspace:*",
    "hono": "^4.7.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250220.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  }
}
